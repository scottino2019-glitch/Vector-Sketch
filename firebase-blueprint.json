{
  "entities": {
    "Sketch": {
      "title": "Sketch",
      "description": "A vector sketch created by a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "canvasData": { "type": "string", "description": "JSON representation of the Fabric.js canvas" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "previewUrl": { "type": "string" }
      },
      "required": ["name", "ownerId", "canvasData", "createdAt", "updatedAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/sketches/{sketchId}": {
      "schema": "Sketch",
      "description": "Collection of all sketches."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    }
  }
}
